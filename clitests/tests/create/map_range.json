            { "outputTolerance": false, "flag": "--format R16G16B16A16_SFLOAT --encode uastc-hdr-4x4 --map-range-auto", "file": "linear_float32_extreme", "ext": ".exr", "name": "UASTC4X4_R16G16B16A16_SFLOAT-map-range-auto" },
        
