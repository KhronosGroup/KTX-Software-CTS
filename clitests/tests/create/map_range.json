            { "outputTolerance": false, "flag": "--format R16G16B16A16_SFLOAT --encode uastc-hdr-6x6i --map-range-auto", "file": "linear_float32", "ext": ".exr", "name": "UASTC6X6I_R16G16B16A16_SFLOAT-map-range-auto" },
