{
    "description": "Test extraction HDR files to EXR output files.",
    "command": "ktx extract --testrun input/ktx2/valid_${subcase}_2D.ktx2 output/extract/exr_hdr_2d/output_${subcase}_2D.exr",
    "status": 0,
    "outputs": {
        "output/extract/exr_hdr_2d/output_${subcase}_2D.exr": "golden/extract/exr_hdr_2d/output_${subcase}_2D.exr"
